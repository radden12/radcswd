# Telegram-бот (получите токен у @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram ID администратора (можно несколько через запятую)
TELEGRAM_ADMIN_IDS=

# GGSEL: данные аккаунта продавца
GGSEL_SELLER_ID=
GGSEL_API_TOKEN=
GGSEL_LOGIN=
GGSEL_PASSWORD=

# Пути проекта (можно не менять)
STORAGE_DIR=storage
PLUGINS_DIR=plugins
LOGS_DIR=logs
CONFIGS_DIR=configs

# Лог-уровень: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Интервал опроса GGSEL (в секундах)
GGSEL_POLL_INTERVAL=10

# Авто-перезапуск при падении
AUTO_RESTART=1

# Hot-reload плагинов
PLUGIN_HOT_RELOAD=1
