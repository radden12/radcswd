# Скопируйте этот файл в .env и заполните значения.

# --- GGSEL ---
# Числовой ID продавца (см. ЛК GGSEL → API).
GGSEL_SELLER_ID=
# Постоянный API-ключ из ЛК GGSEL.
GGSEL_API_KEY=

# --- Telegram bot ---
# Токен от @BotFather.
TG_BOT_TOKEN=
# Список TG user_id-админов через запятую (пусто = доступ открыт).
TG_ADMIN_IDS=

# --- Logging ---
LOG_LEVEL=INFO
